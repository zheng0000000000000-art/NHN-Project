+    usage: { inputTokens: 1, inputCachedTokens: 0, outputTokens: 1, reasoningTokens: 0, totalTokens: 2 }, estimatedCostUsd: null,
+  })}\n`);
+  const refreshed = await tracker.summary({ days: 30 });
+  assert.equal(refreshed.totals.requests, 10_001);
+});

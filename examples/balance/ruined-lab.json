      { "id": "room-4", "enemies": { "hp": 15, "attack": 10, "count": 3 }, "rewards": { "commonDropRate": 0.22, "healAmount": 4 } }
    ],
    "bosses": [
      { "id": "boss-1", "hp": 120, "attack": 14, "healthMultiplier": { "lowUpgradePath": 1.35, "highUpgradePath": 1.1 } }

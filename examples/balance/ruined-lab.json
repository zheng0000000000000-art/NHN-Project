      { "metricId": "room1DeathRate", "minimum": 0, "maximum": 20, "weight": 1 },
      { "metricId": "room3DeathRate", "minimum": 0, "maximum": 35, "weight": 1 },
      { "metricId": "avgRewardPerRun", "minimum": 8, "maximum": 20, "weight": 1 }

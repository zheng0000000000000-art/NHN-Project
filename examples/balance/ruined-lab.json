  "spec": {
    "balanceId": "ruined-lab-v1",
    "objective": "Keep completion, early deaths, and rewards inside explicit target bands.",
    "parameters": { "room3Attack": 8, "room4Attack": 10, "room4EnemyCount": 3 },
    "parameterSpace": [
      { "parameterId": "room3Attack", "path": "rooms/2/enemies/attack", "minimum": 4, "maximum": 10, "step": 2 },
      { "parameterId": "room4Attack", "path": "rooms/3/enemies/attack", "minimum": 6, "maximum": 12, "step": 2 },

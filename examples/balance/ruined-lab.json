    "constraints": ["Never mutate the baseline.", "Return a no-solution result when no candidate satisfies every band."],
    "search": { "deterministic": true, "seed": "42", "strategy": "explicit-grid" },
    "simulation": { "horizon": 1, "runsPerSeed": 500, "seeds": [11, 23, 42, 71, 101], "policies": ["baseline-combat"] }
  },
  "baseline": {
    "schemaVersion": 2,
